<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

  <property name="table.name" value="metric" global="false"/>

  <changeSet author="Lautaro Osinaga" id="12_create_${table.name}_table">
    <createTable tableName="${table.name}">
      <!-- general properties -->
      <column name="id"          type="${type.id}" autoIncrement="true"><constraints nullable="false" primaryKey="true" primaryKeyName="${table.name}_PK"/></column>
      <column name="external_id" type="${type.externalId}"><constraints nullable="false" unique="true" uniqueConstraintName="${table.name}_externalId_UK"/></column>
      <column name="created_at"  type="datetime"><constraints nullable="false"/></column>
      <column name="updated_at"  type="datetime"><constraints nullable="false"/></column>
      <column name="disabled_at" type="datetime"/>

      <!-- custom properties -->
      <column name="ratio" type="int"/>
      <column name="original_image_id" type="${type.id}">
        <constraints nullable="true" foreignKeyName="FK_metric_original_image_id" referencedTableName="image" referencedColumnNames="id"/>
      </column>

      <!-- indicator FK columns -->
      <column name="psnr_indicator_id"      type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_psnr"      referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="enl_indicator_id"       type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_enl"       referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="ssi_indicator_id"       type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_ssi"       referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="smpi_indicator_id"      type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_smpi"      referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="ssim_indicator_id"      type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_ssim"      referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="srs_indicator_id"       type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_srs"       referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="macana_indicator_id"    type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_macana"    referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="entropy_indicator_id"   type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_entropy"   referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="luminance_indicator_id" type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_luminance" referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="contrast_indicator_id"  type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_contrast"  referencedTableName="indicator" referencedColumnNames="id"/></column>
      <column name="structure_indicator_id" type="${type.id}"><constraints nullable="true" foreignKeyName="FK_metric_structure" referencedTableName="indicator" referencedColumnNames="id"/></column>
    </createTable>
  </changeSet>
</databaseChangeLog>
