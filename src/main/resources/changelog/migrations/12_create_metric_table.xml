<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xmlns:pro="http://www.liquibase.org/xml/ns/pro"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd
                      http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                      http://www.liquibase.org/xml/ns/pro             http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd">

    <property  name="table.name"  value="metric" global="false"/>

    <changeSet  author="Lautaro Osinaga"  id="10_create_${table.name}_table" >
        <createTable tableName="${table.name}" >
            <!-- general properties -->
            <column  name="id"          type="${type.id}"   autoIncrement="true" remarks="GenericModel"   >    <constraints nullable="false" primaryKey="true" primaryKeyName="${table.name}_PK" />                  </column>
            <column  name="external_id" type="${type.externalId}" remarks="PublicModel" > <constraints nullable="false" unique="true"     uniqueConstraintName="${table.name}_externalId_UK" /> </column>
            <column  name="created_at"  type="datetime"     remarks="AuditableModel" >    <constraints nullable="false" />                                                                  </column>
            <column  name="updated_at"  type="datetime"     remarks="AuditableModel" >    <constraints nullable="false" />                                                                  </column>
            <column  name="disabled_at" type="datetime"     remarks="AuditableModel" />

            <!-- cutom properties -->
            <column  name="ratio"       type="int">                                             </column>
            <!-- Relación con Indicator ENL -->
            <column name="enl_indicator_id" type="int">
                <constraints nullable="true" foreignKeyName="FK_${table.name}_enl_indicator_id" referencedTableName="indicator" referencedColumnNames="id"/>
            </column>

            <!-- Relación con Indicator SSI -->
            <column name="ssi_indicator_id" type="int">
                <constraints nullable="true" foreignKeyName="FK_${table.name}_ssi_indicator_id" referencedTableName="indicator" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
